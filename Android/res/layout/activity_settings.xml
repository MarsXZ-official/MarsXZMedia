<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Верхняя панель -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/topTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Настройки приложения"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/backButton" />

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="Назад"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            app:tint="#333333"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/topRedLine"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#E62117"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/topRedLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVideoPathLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Путь к Video и Audio:"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/tvVideoPath"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="8dp"
                    android:background="#EEE"
                    android:text="Используется путь по умолчанию"
                    android:singleLine="true"
                    android:inputType="textUri"/>

                <Button
                    android:id="@+id/btnSelectVideoPath"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..." />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMusicPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Путь к Audio:"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/tvMusicPath"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:padding="8dp"
                        android:background="#EEE"
                        android:text="Используется путь по умолчанию"
                        android:singleLine="true"
                        android:inputType="textUri"/>

                    <Button
                        android:id="@+id/btnSelectMusicPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..." />
                </LinearLayout>
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbSeparatePaths"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отдельно" />

            <CheckBox
                android:id="@+id/cbNoSubfolders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Не создавать папки" />

            <CheckBox
                android:id="@+id/cbDontOpenFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Не открывать скачанный файл" />

            <CheckBox
                android:id="@+id/cbUseDefaultPath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Использовать путь по умолчанию" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCC"
                android:layout_marginVertical="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Логирование"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnExportLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Экспорт логов"
                android:layout_gravity="center" />

            <CheckBox
                android:id="@+id/cbDisableLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Не создавать логи"
                android:layout_gravity="center" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Хранить (дней): " />

                <EditText
                    android:id="@+id/etMaxDays"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:gravity="center" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbInfiniteLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Безгранично"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tvErrorInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF0000"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>