<Window Icon="/Assets/Icons/MarsXZMedia.png" xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MarsXZMedia.AboutWindow"
        Title="О программе"
        Width="560"
        Height="540"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="0">
            
            <TextBlock Text="MarsXZ Media v1.2.0"
                       FontFamily="{DynamicResource AppFontBold}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#000000"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="MarsXZ Media — настольный инструмент для эффективной загрузки видео и аудио с YouTube."
                       FontSize="16"
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock Text="• Загрузка выполняется с использованием мощного движка yt-dlp."
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <TextBlock Text="• Обработка, объединение и конвертация файлов выполняются через FFmpeg."
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <TextBlock Text="• Node.js используется для корректной работы внутренних компонентов."
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <Separator Background="#CCCCCC" Height="1" Margin="0,0,0,16"/>

            <TextBlock Text="Сообщить об ошибке"
                       FontFamily="{DynamicResource AppFontBold}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#111111"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Если вы обнаружили ошибку или недочёт в работе MarsXZ Media, напишите:"
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Border BorderBrush="#1a73e8"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,4"
                    Background="Transparent"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16">
                
                <TextBlock x:Name="SupportEmailLink"
                           Text="marsxz8656@gmail.com"
                           Foreground="#1a73e8"
                           FontSize="14"
                           Cursor="Hand"
                           FontWeight="SemiBold"
                           PointerPressed="OpenSupportEmail"/>
            </Border>

            <TextBlock x:Name="EmailStatus"
                       Text=""
                       Foreground="#666666"
                       FontSize="12"
                       IsVisible="False"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <Separator Background="#CCCCCC" Height="1" Margin="0,0,0,16"/>

            <TextBlock Text="© MarsXZ, 2026. Все права защищены."
                       Foreground="#666666"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Проект использует компоненты с открытым исходным кодом."
                       Foreground="#666666"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <Button Content="Закрыть"
                    FontFamily="{DynamicResource AppFont}"
                    Width="140"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="Close_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>