<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MarsXZMedia.HistoryView"
             Background="White">
  <DockPanel>
    <TextBlock Text="История запросов"
               FontSize="24"
               FontWeight="SemiBold"
              
              
               Margin="16,16,16,8"
               DockPanel.Dock="Top"/>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
      <Border Background="Transparent" Padding="12" Margin="16,0,16,16">
        <StackPanel x:Name="GroupsPanel"
                    Spacing="12"
                    Margin="16,0,16,16"/>
      </Border>
    </ScrollViewer>
  </DockPanel>
</UserControl>

