<Window Icon="/Assets/Icons/MarsXZMedia.png" xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MarsXZMedia.MainWindow"
        Title="MarsXZ Media" 
        MinWidth="620" 
        MinHeight="500" 
        SizeToContent="Height"
        Width="620"
        Background="White">

    
    <Window.Styles>
        <Style Selector="Button.mc-btn">
            <Setter Property="FontFamily" Value="{StaticResource McFont}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-gray">
            <Setter Property="Background" Value="#7C7C7C"/>
            <Setter Property="BorderBrush" Value="#2F2F2F"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-green">
            <Setter Property="Background" Value="#3C8527"/>
            <Setter Property="BorderBrush" Value="#1E4613"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-wood">
            <Setter Property="Background" Value="#A1744B"/>
            <Setter Property="BorderBrush" Value="#3D2B1F"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-stone">
            <Setter Property="Background" Value="#6D6D6D"/>
            <Setter Property="BorderBrush" Value="#2F2F2F"/>
        </Style>

        <Style Selector="Button.mc-btn.mc-btn-youtube">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="BorderBrush">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF5A4F" Offset="0"/>
                    <GradientStop Color="#8B0000" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-gray:pointerover">
            <Setter Property="Background" Value="#8A8A8A"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-green:pointerover">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="BorderBrush" Value="#2F6E1C"/>
        </Style>

        <Style Selector="Button.mc-btn.mc-btn-green:pressed">
            <Setter Property="Background" Value="#2F6E1C"/>
            <Setter Property="BorderBrush" Value="#16350E"/>
            <Setter Property="RenderTransform">
                <TranslateTransform Y="2"/>
            </Setter>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-wood:pointerover">
            <Setter Property="Background" Value="#B8865A"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.mc-btn.mc-btn-stone:pointerover">
            <Setter Property="Background" Value="#8A8A8A"/>
            <Setter Property="BorderBrush" Value="#E6E6E6"/>
        </Style>

        <Style Selector="Button.mc-btn.mc-btn-youtube:pointerover">
            <Setter Property="Background" Value="#E60000"/>
            <Setter Property="BorderBrush">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF7A70" Offset="0"/>
                    <GradientStop Color="#A00000" Offset="1"/>
                </LinearGradientBrush>
            </Setter>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ГЛАВНАЯ" Click="OpenMain_Click"/>
            <MenuItem Header="ИСТОРИЯ" Click="OpenHistory_Click"/>
            <MenuItem Header="НАСТРОЙКИ" Click="OpenSettings_Click"/>
        </Menu>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid TextElement.FontSize="18" Margin="0,0,0,20">
                <ContentControl x:Name="MainContent">
                    <StackPanel Margin="15" Spacing="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox x:Name="UrlBox" Watermark="Вставьте ссылку..." MinHeight="52" CornerRadius="0" BorderBrush="#555555" BorderThickness="2" VerticalContentAlignment="Center" TextChanged="OnUrlTextChanged"/>
                            <Button Grid.Column="1" Content="ВСТАВИТЬ" Click="OnPasteClick" Classes="mc-btn mc-btn-stone" FontSize="16" MinWidth="130" MinHeight="52" Margin="10,0,0,0"/>
                        </Grid>
                                                                        <Button x:Name="FindButton"
                                Content="ИСКАТЬ ВИДЕО"
                                Click="FetchInfo"
                                Classes="mc-btn mc-btn-youtube"
                                FontSize="22"
                                FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                MinHeight="56"
                                IsEnabled="False"/>


                        <StackPanel x:Name="InfoPanel" IsVisible="False" Spacing="16">
                            <Grid ColumnDefinitions="240, *" RowDefinitions="Auto">
                                <Border Grid.Column="0" CornerRadius="12" ClipToBounds="True" Height="135" Background="Black" BoxShadow="0 2 8 0 #20000000">
                                    <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="5" VerticalAlignment="Center">
                                    <TextBlock x:Name="VideoTitle" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" MaxLines="3"/>
                                    <TextBlock x:Name="VideoDescription1" FontSize="15" Foreground="#555555" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="3"/>
                                    <TextBlock x:Name="VideoAuthor" FontSize="15" FontWeight="SemiBold" Foreground="#444444"/>
                                    <TextBlock x:Name="VideoDuration" FontSize="14" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>

                            <Separator Height="1" Background="#DCDCDC"/>

                            <Label Content="Выберите тип скачивания:" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,4"/>
                            <ComboBox x:Name="DownloadTypeList" 
                                      MinHeight="52"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0" 
                                      SelectionChanged="DownloadTypeChanged">
                                <ComboBoxItem Content="Видео (MP4)"/>
                                <ComboBoxItem Content="Аудио (MP3)"/>
                            </ComboBox>

                            <Label x:Name="QualityOrBitrateLabel" Content="Выберите качество:" FontWeight="SemiBold" FontSize="17"/>
                            <ComboBox x:Name="QualityOrBitrateList" 
                                      MinHeight="52"
                                      VerticalContentAlignment="Center"
                                      HorizontalAlignment="Stretch" 
                                      SelectionChanged="OnQualityOrBitrateChanged"/>

                            <Label x:Name="AudioLabel" Content="Выберите звуковую дорожку:" FontWeight="SemiBold" FontSize="17" IsVisible="False"/>
                            <ComboBox x:Name="AudioList" MinHeight="52" HorizontalAlignment="Stretch" IsVisible="False"/>

                            <Separator Height="1" Background="#DCDCDC" Margin="0,10"/>
                        <Button x:Name="DownloadButton" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                                Content="СКАЧАТЬ РЕСУРСЫ" 
                                Click="Download" 
                                Classes="mc-btn mc-btn-green"
                                FontSize="24"
                                FontWeight="Bold" 
                                Foreground="#55FF55" 
                                MinHeight="54" 
                                Padding="0,10"
                                HorizontalAlignment="Stretch" 
                                IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>


