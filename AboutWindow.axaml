<Window Icon="/Assets/Icons/MarsXZMedia.png" xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MarsXZMedia.AboutWindow"
        Title="О программе"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="10">
            <TextBlock Text="MarsXZ Media v1.1.0"
                       FontFamily="{StaticResource McFont}"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="MarsXZ Media — настольный инструмент для загрузки видео и аудио с YouTube."
                       TextWrapping="Wrap"/>
            <TextBlock Text="Загрузка выполняется с использованием yt-dlp."
                       TextWrapping="Wrap"/>
            <TextBlock Text="Обработка, объединение и конвертация файлов выполняются через ffmpeg."
                       TextWrapping="Wrap"/>
            <TextBlock Text="node используется для корректной работы внутренних компонентов."
                       TextWrapping="Wrap"/>

            <Separator/>

            <TextBlock Text="Сообщить об ошибке"
                       FontFamily="{StaticResource McFont}"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock Text="Если вы обнаружили ошибку или недочёт в работе MarsXZ Media, напишите:"
                       TextWrapping="Wrap"/>
            <Border BorderBrush="#1a73e8"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="4,2"
                    Background="Transparent"
                    HorizontalAlignment="Left">
                <TextBlock x:Name="SupportEmailLink"
                           Text="marsxz8656@gmail.com"
                           Foreground="#1a73e8"
                           TextDecorations="Underline"
                           Cursor="Hand"
                           FontWeight="SemiBold"
                           PointerPressed="OpenSupportEmail"/>
            </Border>
            <TextBlock x:Name="EmailStatus"
                       Text=""
                       Foreground="#666666"
                       FontSize="12"
                       IsVisible="False"
                       TextWrapping="Wrap"/>

            <Separator/>

            <TextBlock Text="© MarsXZ, 2026. Все права защищены."
                       TextWrapping="Wrap"/>
            <TextBlock Text="Сторонние компоненты используются по лицензии их авторов."
                       TextWrapping="Wrap"/>

            <Button Content="Закрыть"
                    FontFamily="{StaticResource McFont}"
                    Width="140"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="Close_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>



